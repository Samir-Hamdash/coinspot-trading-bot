# CoinSpot API credentials
# Get these from: https://www.coinspot.com.au/my/api
# For paper mode: Read Only is sufficient
# For live trading: enable Read + Trade permissions
COINSPOT_API_KEY=your_coinspot_api_key_here
COINSPOT_API_SECRET=your_coinspot_api_secret_here

# Trading mode: "paper" (simulated) or "real" (real money)
TRADING_MODE=paper

# Second confirmation required to enable real trading.
# BOTH TRADING_MODE=real AND REAL_TRADING_CONFIRMED=true must be set.
REAL_TRADING_CONFIRMED=false

# Starting paper balance in AUD
PAPER_BALANCE=1000

# Bot interval in seconds (default: 60)
BOT_INTERVAL_SECONDS=60

# Database paths
DB_PATH=trading_bot.db
BACKUP_PATH=memory_backup.json

# MCP server port (optional — only needed if running MCP server over HTTP
# instead of stdio. Claude desktop uses stdio by default; leave this unset.)
# MCP_PORT=3000
